FROM python:3.12-slim

# System deps: git (for cloning repos) + curl (for opengrep/trufflehog download)
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

# Install OpenGrep binary (auto-detect arch: amd64 or arm64)
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then \
        OPENGREP_URL="https://github.com/opengrep/opengrep/releases/latest/download/opengrep_manylinux_x86"; \
    else \
        OPENGREP_URL="https://github.com/opengrep/opengrep/releases/latest/download/opengrep_manylinux_aarch64"; \
    fi && \
    curl -fsSL "$OPENGREP_URL" -o /usr/local/bin/opengrep && \
    chmod +x /usr/local/bin/opengrep

# Install TruffleHog binary (auto-detect arch: amd64 or arm64)
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then \
        TH_ARCH="amd64"; \
    else \
        TH_ARCH="arm64"; \
    fi && \
    TH_VERSION=$(curl -fsSL https://api.github.com/repos/trufflesecurity/trufflehog/releases/latest | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/') && \
    curl -fsSL "https://github.com/trufflesecurity/trufflehog/releases/latest/download/trufflehog_${TH_VERSION}_linux_${TH_ARCH}.tar.gz" | \
    tar -xz -C /usr/local/bin trufflehog && \
    chmod +x /usr/local/bin/trufflehog

WORKDIR /app

# Install Python dependencies
COPY backend/requirements.txt backend/requirements.txt
RUN pip install --no-cache-dir -r backend/requirements.txt

# Copy application code
COPY backend/ backend/

# Copy utility scripts
COPY add_user.py .
COPY view_db.py .

# Copy GitHub App private key if it exists (handles both .pem and .private-key.pem)
# This step is optional - if the file doesn't exist, the build will continue
# Note: Docker COPY doesn't support conditional copying, so we handle this via env vars instead

# Database and scanned repos live on a mounted volume
ENV DATABASE_PATH=/data/vulnmonk.db

# Create directories
RUN mkdir -p /data /app/projects

EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
